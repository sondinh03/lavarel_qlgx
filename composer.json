{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "require": {
        "php": "^7.3|^8.0",
        "backpack/backupmanager": "^3.0",
        "backpack/crud": "4.1.*",
        "backpack/filemanager": "^1.1",
        "backpack/logmanager": "^4.0",
        "backpack/pagemanager": "^3.0.0",
        "backpack/permissionmanager": "^6.0",
        "backpack/revise-operation": "^1.0",
        "backpack/settings": "^3.1",
        "ckfinder/ckfinder-laravel-package": "^3.5.3",
        "cocur/slugify": "^4.6",
        "dietercoopman/smart": "^2.0",
        "fruitcake/laravel-cors": "^2.0",
        "guzzlehttp/guzzle": "^7.0.1",
        "laravel/framework": "^8.75",
        "laravel/helpers": "^1.7",
        "laravel/sanctum": "^2.11",
        "laravel/telescope": "^5.7",
        "laravel/tinker": "^2.5",
        "laravel/ui": "^3.0",
        "livewire/livewire": "2.12",
        "maatwebsite/excel": "^3.1",
        "nesbot/carbon": "^2.73",
        "phpoffice/phpspreadsheet": "^1.29",
        "predis/predis": "^3.4",
        "spatie/laravel-settings": "^3.4",
        "stolz/assets": "^0.2.0"
    },
    "require-dev": {
        "backpack/generators": "^3.1",
        "facade/ignition": "^2.5",
        "fakerphp/faker": "^1.9.1",
        "laravel/sail": "^1.0.1",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^5.10",
        "phpunit/phpunit": "^9.5.10"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Support/Helps.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "audit": {
        "abandoned": "ignore",
        "block-insecure": false
    }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": {
        "backpack/devtools": {
            "type": "composer",
            "url": "https://repo.backpackforlaravel.com"
        }
    }
}
